# Másold: cp deploy/.env.example deploy/.env
# A deploy/.env SOHA nem kerül git-be

# Postgres jelszó (találj ki egy erőset)
DB_PASSWORD=change_me_strong_password_here

# FastAPI JWT kulcs (min. 32 véletlenszerű karakter)
SECRET_KEY=change_me_min_32_chars_random_string

# Az app publikus domainje
APP_DOMAIN=halo-leltar.otthonkapocs.hu
